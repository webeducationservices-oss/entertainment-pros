{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "ALLOWALL"
        },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors *"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/edit",
      "destination": "https://myaieditor.com",
      "permanent": false
    },
    {
      "source": "/motorized-pull-down-tv-mount-installation",
      "destination": "/motorized-tv-mount-installation",
      "permanent": true
    },
    {
      "source": "/when-work-goes-wrong",
      "destination": "/av-professionals-matter",
      "permanent": true
    },
    {
      "source": "/contact-thank-you-page",
      "destination": "/contact",
      "permanent": true
    }
  ]
}